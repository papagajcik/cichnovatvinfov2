{
  "name": "securenetxzone",
  "version": "1.0.0",
  "main": "main.js",
  "scripts": {
    "build": "electron-builder"
  },
  "devDependencies": {
    "electron": "^25.0.0",
    "electron-builder": "latest"
  },
  "build": {
    "appId": "com.snxz.snxzcz",
    "productName": "SecureNetXZone",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "portable"
    },
    "mac": {
      "target": ["dmg"],
      "arch": ["x64", "arm64"],
      "category": "public.app-category.utilities"
    }
  }
}
